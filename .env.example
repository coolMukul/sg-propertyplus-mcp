# SG-PropertyPlus MCP Server — Environment Configuration
# Copy this file to .env and adjust values as needed.
# Loaded via Node's --env-file flag (see package.json scripts).

# --- Defaults ---
RADIUS_DEFAULT=50
RADIUS_MIN=10
RADIUS_MAX=5000
HDB_LIMIT_DEFAULT=10
ARCGIS_RESULT_LIMIT=50

# --- OneMap (free registration at https://www.onemap.gov.sg/apidocs/register) ---
# Enables enhanced geocoding for Singapore addresses.
# Without these, the server falls back to a slower geocoding provider.
# Option 1: Paste the access token (expires every 3 days)
# ONEMAP_TOKEN=eyJ...your_token_here
# Option 2: Email/password for automatic token refresh (recommended)
# ONEMAP_EMAIL=your@email.com
# ONEMAP_PASSWORD=your_password

# --- URA Data Service (free registration at https://eservice.ura.gov.sg/maps/api/reg.html) ---
# Enables private property transactions, rentals, developer sales, and pipeline data.
# URA_ACCESS_KEY=your_access_key_here

# --- LTA DataMall (free registration at https://datamall.lta.gov.sg) ---
# Enables bus stops, real-time bus arrivals, and taxi availability.
# LTA_ACCOUNT_KEY=your_account_key_here

# --- Transport (default: stdio) ---
# TRANSPORT=http
# HTTP_MODE=stateful
# HTTP_PORT=3000
