{
  "name": "sg-propertyplus-mcp",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "sg-propertyplus-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "dev:http": "TRANSPORT=http tsx watch --env-file=.env src/index.ts",
    "dev:http:stateless": "TRANSPORT=http HTTP_MODE=stateless tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "start:http": "TRANSPORT=http node --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
